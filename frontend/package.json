{
  "name": "nextjs-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn graphql:generate && next dev",
    "build": "yarn graphql:prod:generate && next build",
    "serve:prod": "yarn build && next start -p 4000",
    "lint": "next lint",
    "graphql:generate": "graphql-codegen --config codegen.development.yml",
    "graphql:prod:generate": "graphql-codegen --config codegen.production.yml"
  },
  "dependencies": {
    "graphql": "^15.5.1",
    "graphql-request": "^3.5.0",
    "next": "11.0.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-query": "^3.19.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^2.0.1",
    "@graphql-codegen/typescript": "^2.0.0",
    "@graphql-codegen/typescript-operations": "^2.0.1",
    "@graphql-codegen/typescript-react-query": "^2.0.0",
    "@types/react": "17.0.16",
    "autoprefixer": "^10.3.2",
    "eslint": "7.32.0",
    "eslint-config-next": "11.0.1",
    "postcss": "^8.3.6",
    "tailwindcss": "^2.2.7",
    "typescript": "4.3.5"
  }
}
