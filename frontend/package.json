{
  "name": "nextjs-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn graphql:generate && next dev",
    "build": "yarn graphql:prod:generate && next build",
    "serve:prod": "yarn build && next start -p 4000",
    "lint": "next lint",
    "graphql:generate": "graphql-codegen --config codegen.development.yml",
    "graphql:prod:generate": "graphql-codegen --config codegen.production.yml"
  },
  "dependencies": {
    "@heroicons/react": "^1.0.4",
    "aos": "^3.0.0-beta.6",
    "daisyui": "^2.8.0",
    "graphql": "^16.3.0",
    "graphql-request": "^4.1.0",
    "next": "^12.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-query": "^3.34.16",
    "tailwind-scrollbar-hide": "^1.0.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^2.6.2",
    "@graphql-codegen/typescript": "^2.4.7",
    "@graphql-codegen/typescript-operations": "^2.3.4",
    "@graphql-codegen/typescript-react-query": "^3.5.7",
    "@types/aos": "^3.0.4",
    "@types/react": "17.0.16",
    "autoprefixer": "^10.3.2",
    "eslint": "^8.11.0",
    "eslint-config-next": "^12.1.0",
    "postcss": "^8.4.11",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.6.2"
  }
}
